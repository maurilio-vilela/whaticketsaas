						"senderTimestampMs": msg?.message?.pollUpdateMessage?.senderTimestampMs || null,
						"voteEncrypted": true,
						"vote": {
							"encPayload": msg?.message?.pollUpdateMessage?.vote?.encPayload || null,
							"encIv": msg?.message?.pollUpdateMessage?.vote?.encIv || null,
						},
						"participant": (msg?.key?.participant || '').split('@')[0] || null,
						"datetime": moment(msg?.messageTimestamp * 1000)?.format('YYYY-MM-DD HH:mm:ss')
					};
					//
					break;
				case 'editedMessage':
					//
					response = {
						"SessionName": `${SessionName}`,
						"wook": msg?.key?.fromMe == true ? 'SEND_MESSAGE' : 'RECEIVE_MESSAGE',
						"status": msg?.key?.fromMe == true ? 'SEND' : 'RECEIVED',
						"type": 'editedMessage',
						"fromMe": msg?.key?.fromMe,
						"id": msg?.key?.id,
						"name": msg?.pushName || msg?.verifiedBizName || null,
						"from": msg?.key?.fromMe == true ? phone : msg?.key?.remoteJid?.split('@')[0],
						"to": msg?.key?.fromMe == false ? phone : msg?.key?.remoteJid?.split('@')[0],
						"isPrivate": msg?.key?.remoteJid.endsWith('@s.whatsapp.net'),
						"isGroup": msg?.key?.remoteJid?.endsWith('@g.us'),
						"content": msg.message.editedMessage?.message?.protocolMessage?.editedMessage?.conversation || null,
						"originalMessageId": msg.message.editedMessage?.message?.protocolMessage?.key?.id || null,
						"participant": (msg?.key?.participant || '').split('@')[0] || null,
						"datetime": moment(msg?.messageTimestamp * 1000)?.format('YYYY-MM-DD HH:mm:ss')
					};
					//
					break;
				case 'ephemeralMessage':
					logger?.info('Message type: ephemeralMessage');
					//
					response = {
						"SessionName": `${SessionName}`,
						"wook": msg?.key?.fromMe == true ? 'SEND_MESSAGE' : 'RECEIVE_MESSAGE',
						"status": msg?.key?.fromMe == true ? 'SEND' : 'RECEIVED',
						"type": 'ephemeralMessage',
						"fromMe": msg?.key?.fromMe,
						"id": msg?.key?.id,
						"name": msg?.pushName || msg?.verifiedBizName || null,
						"from": msg?.key?.fromMe == true ? phone : msg?.key?.remoteJid?.split('@')[0],
						"to": msg?.key?.fromMe == false ? phone : msg?.key?.remoteJid?.split('@')[0],
						"isPrivate": msg?.key?.remoteJid.endsWith('@s.whatsapp.net'),
						"isGroup": msg?.key?.remoteJid?.endsWith('@g.us'),
						"content": msg?.message?.ephemeralMessage?.message?.extendedTextMessage?.text || null,
						"expiration": moment(msg?.message?.ephemeralMessage?.message?.extendedTextMessage?.contextInfo?.expiration * 1000)?.format('YYYY-MM-DD HH:mm:ss'),
						"ephemeralSetting": moment(msg?.message?.ephemeralMessage?.message?.extendedTextMessage?.contextInfo?.ephemeralSettingTimestamp * 1000)?.format('YYYY-MM-DD HH:mm:ss'),
						"participant": (msg?.key?.participant || '').split('@')[0] || null,
						"datetime": moment(msg?.messageTimestamp * 1000)?.format('YYYY-MM-DD HH:mm:ss')
					}
					break;
				default:
					//
					response = {};
				//
			}

			if (whMessage && webhook) {
				//
				if (Object.keys(response).length !== 0) {
					let dataJson = JSON.stringify(response, null, 2);
					await axios.post(webhook, dataJson, {
						httpsAgent: new https.Agent({
							rejectUnauthorized: false,
							keepAlive: true
						}),
						headers: {
							'Content-type': 'application/json; charset=utf-8',
							'Accept': 'application/json; charset=utf-8'
						}
					}).then(response => {
						logger?.warn('Webhook message send')
					}).catch(error => {
						logger?.error(`Webhook error message send: ${error.message}`);
					});
				}
				//
			} else {
				logger?.warn('Webhook message disable');
			}
		}
	} catch (error) {
		logger?.error(`Webhook error message: ${error.message}`);
	};
};

export const whConnect = async (
	whatsapp: Whatsapp,
	lastDisconnect: any
): Promise<any> => {
	try {
		//
		const resWhatsapp = await Whatsapp.findOne({ where: { id: whatsapp.id } });
		//
		const name = resWhatsapp?.name;
		const whConnect = resWhatsapp?.whConnect;
		const webhook = resWhatsapp?.webhookCli ? resWhatsapp?.webhookCli : null;
		//
		const resDisconnectReason = {
			loggedOpen: 'loggedOpen', // Manual
			loggedQr: 'loggedQr', // Manual
			genericOut: 400,
			loggedOut: 401, // Desconectado de outro dispositivo
			bannedTimetamp: 402, // O código de status 402 possui um timestamp de banimento, conta temporariamente banida
			bannedTemporary: 403, // Agora chamado de LOCKED no código do WhatsApp Web, conta banida, dispositivo principal foi desconectado
			clientOutdated: 405, // Cliente desatualizado
			unknownLogout: 406, // Agora chamado de BANNED no código do WhatsApp Web, desconectado por motivo desconhecido
			timedOut: 408, // Conexão expirada, reconectando...
			connectionLost: 408, // Conexão perdida com o servidor, reconectando...
			dadUserAgent: 409, // O agente do usuário do cliente foi rejeitado
			multideviceMismatch: 411, // Incompatibilidade de múltiplos dispositivos, escaneie novamente...
			CATExpired: 413, // O token de autenticação criptográfica do Messenger expirou
			CATInvalid: 414, // O token de autenticação criptográfica do Messenger é inválido
			notFound: 415,
			connectionClosed: 428, // Conexão fechada, reconectando...
			connectionReplaced: 440, // Conexão substituída, outra nova sessão foi aberta e reconectada...
			badSession: 500, // Arquivo de sessão corrompido, exclua a sessão e escaneie novamente.
			experimental: 501,
			serviceUnavailable: 503,
			restartRequired: 515,
		};
		//
		const	statusCode = lastDisconnect;
		var response:any;
		//
		switch (statusCode) {
			case resDisconnectReason.loggedOpen:
				// Device Logged Out, Deleting Session
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection loggedOpen`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "CONNECTED",
					status: "inChat",
					message: "Sistema iniciado e disponivel para uso"
				};
				//
				break;
			case resDisconnectReason.loggedQr:
				// Device Logged Out, Deleting Session
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection loggedQr`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "QRCODE",
					status: "qrRead",
					message: "Sistema aguardando leitura do QR-Code"
				};
				//
				break;
			case resDisconnectReason.loggedOut:
				// Device Logged Out, Deleting Session
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection loggedOut`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "CLOSED",
					status: "notLogged",
					message: "Sistema desconectado"
				};
				//
				break;
			case resDisconnectReason.bannedTemporary:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info(`User banned temporary`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "BANNED",
					status: "notLogged",
					message: "Sistema desconectado"
				};
				//
				break;
			case resDisconnectReason.bannedTimetamp:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info(`User banned timestamp`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "BANNED",
					status: "notLogged",
					message: "Sistema desconectado"
				};
				//
				break;
			case resDisconnectReason.timedOut:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection TimedOut`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "CONNECTING",
					status: "desconnectedMobile",
					message: "Dispositivo conectando"
				};
				//
				break;
			case resDisconnectReason.connectionLost:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection Los`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					message: "Dispositivo conectando",
					state: "CONNECTING",
					status: "desconnectedMobile"
				};
				//
				break;
			case resDisconnectReason.multideviceMismatch:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Connection multideviceMismatch');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					message: "Dispositivo conectando",
					state: "CONNECTING",
					status: "desconnectedMobile"
				};
				//
				break;
			case resDisconnectReason.connectionClosed:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection connectionClosed`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					message: "Sistema desconectado",
					state: "CLOSED",
					status: "notLogged"
				};
				//
				break;
			case resDisconnectReason.connectionReplaced:
				//
				// Connection Replaced, Another New Session Opened, Please Close Current Session First
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection connectionReplaced`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "DISCONNECTED",
					status: "notLogged",
					message: "Dispositivo desconectado"
				};
				//
				break;
			case resDisconnectReason.badSession:
				//
				// Bad session file, delete and run again
				logger?.info(`SessionName: ${name}`);
				logger?.info(`Connection badSession`);
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "DISCONNECTED",
					status: "notLogged",
					message: "Dispositivo desconectado"
				};
				//
				break;
			case resDisconnectReason.restartRequired:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Connection restartRequired');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					message: "Sistema desconectado",
					state: "CLOSED",
					status: "notLogged"
				};
				//
				break;
			case resDisconnectReason.genericOut:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Generic Error');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "ERROR",
					status: "genericError",
					message: "Erro genérico"
				};
				//
				break;
			case resDisconnectReason.clientOutdated:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Client Outdated');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "OUTDATED",
					status: "updateRequired",
					message: "Cliente desatualizado, atualização necessária"
				};
				//
				break;
			case resDisconnectReason.unknownLogout:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Unknown Logout Reason');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "CLOSED",
					status: "notLogged",
					message: "Logout desconhecido"
				};
				//
				break;
			case resDisconnectReason.dadUserAgent:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Bad User Agent');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "ERROR",
					status: "invalidUserAgent",
					message: "User Agent inválido"
				};
				//
				break;
			case resDisconnectReason.CATExpired:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Crypto Auth Token Expired');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "AUTH_FAILED",
					status: "tokenExpired",
					message: "Token de autenticação criptografada expirado"
				};
				//
				break;
			case resDisconnectReason.CATInvalid:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Invalid Crypto Auth Token');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "AUTH_FAILED",
					status: "invalidToken",
					message: "Token de autenticação criptografada inválido"
				};
				//
				break;
			case resDisconnectReason.notFound:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Resource Not Found');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "ERROR",
					status: "resourceNotFound",
					message: "Recurso não encontrado"
				};
				//
				break;
			case resDisconnectReason.experimental:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Experimental Feature Issue');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "ERROR",
					status: "experimental",
					message: "Problema de Recurso Experimental"
				};
				//
				break;
			case resDisconnectReason.serviceUnavailable:
				//
				logger?.info(`SessionName: ${name}`);
				logger?.info('Service Unavailable');
				//
				response = {
					SessionName: name,
					wook: "STATUS_CONNECT",
					state: "ERROR",
					status: "serviceUnavailable",
					message: "Serviço Indisponível"
				};
				//
				break;
			default:
				//
				//logger?.warn(`lastDisconnect: ${lastDisconnect?.error}`);
				//
				response = {};
			//
		}
		//
		if (whConnect && webhook) {
			//
			if (Object.keys(response).length !== 0) {
				let dataJson = JSON.stringify(response, null, 2);
				await axios.post(webhook, dataJson, {
					httpsAgent: new https.Agent({
						rejectUnauthorized: false,
						keepAlive: true
					}),
					headers: {
						'Content-type': 'application/json; charset=utf-8',
						'Accept': 'application/json; charset=utf-8'
					}
				}).then(response => {
					logger?.warn('Webhook connect send')
				}).catch(error => {
					logger?.error(`Webhook error connect send: ${error.message}`);
				});
			}
			//
		} else {
			logger?.warn('Webhook connect disable');
		}
	} catch (error) {
		logger?.error(`Webhook error connect: ${error.message}`);
	};
};

export const whQrcode = async (
	whatsapp: Whatsapp,
	qrcode: string
): Promise<any> => {
	try {
		//
		const resWhatsapp = await Whatsapp.findOne({ where: { id: whatsapp.id } });
		//
		const name = resWhatsapp?.name;
		const whQrcode = resWhatsapp?.whQrcode;
		const webhook = resWhatsapp?.webhookCli ? resWhatsapp?.webhookCli : null;
		//
		let response = {
			"SessionName": name,
			"state": "QRCODE",
			"status": "qrRead",
			"qrcode": qrcode
		}
		//
		if (whQrcode && webhook) {
			//
			if (Object.keys(response).length !== 0) {
				let dataJson = JSON.stringify(response, null, 2);
				await axios.post(webhook, dataJson, {
					httpsAgent: new https.Agent({
						rejectUnauthorized: false,
						keepAlive: true
					}),
					headers: {
						'Content-type': 'application/json; charset=utf-8',
						'Accept': 'application/json; charset=utf-8'
					}
				}).then(response => {
					logger?.warn('Webhook qrcode send')
				}).catch(error => {
					logger?.error(`Webhook error qrcode send: ${error.message}`);
				});
			}
			//
		} else {
			logger?.warn('Webhook qrcode disable');
		}
	} catch (error) {
		logger?.error(`Webhook error qrcode: ${error.message}`);
	};
};